{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ParsedSpec Array",
  "description": "An array of specifications for different layers.",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "name": {
        "type": "string",
        "description": "Optional name for the specification layer."
      },
      "unit": {
        "type": "string",
        "description": "The unit of analysis (e.g., 'segment', 'node').",
        "enum": ["segment", "node", "point"]
      },
      "unitDivide": {
        "type": "number",
        "description": "A division factor for the unit."
      },
      "zoom": {
        "type": "number",
        "description": "The zoom level for the map."
      },
      "method": {
        "type": "string",
        "description": "The rendering method (e.g., 'line', 'rect', 'matrix', 'point', 'heatmap').",
        "enum": ["line", "rect", "matrix", "point", "heatmap"]
      },
      "lineOpacity": {
        "oneOf": [
          { "type": "string" },
          { "type": "number" }
        ],
        "description": "Opacity for lines, can be a number or a string (e.g., a field name)."
      },
      "lineColor": {
        "type": "string",
        "description": "Color for lines."
      },
      "lineType": {
        "type": "string",
        "description": "Type of line (e.g., 'dashed', 'dotted').",
        "nullable": true
      },
      "lineStrokeWidth": {
        "oneOf": [
          { "type": "string" },
          { "type": "number" }
        ],
        "description": "Stroke width for lines."
      },
      "lineHeight": {
        "oneOf": [
          { "type": "string" },
          { "type": "number" }
        ],
        "description": "Height for lines."
      },
      "chart": {
        "type": "object",
        "description": "Optional Vega-Lite chart specification.",
        "additionalProperties": true,
        "nullable": true
      },
      "orientation": {
        "type": "string",
        "description": "Orientation for rendering (e.g., 'parallel', 'perpendicular').",
        "enum": ["parallel", "perpendicular"]
      },
      "alignment": {
        "type": "string",
        "description": "Alignment for rendering (e.g., 'left', 'center', 'right').",
        "enum": ["left", "center", "right"]
      },
      "physicalLayerPath": {
        "type": "string",
        "description": "Path to the physical layer data (e.g., GeoJSON file).",
        "nullable": true
      },
      "thematicLayerPath": {
        "type": "string",
        "description": "Path to the thematic layer data (e.g., CSV file for points).",
        "nullable": true
      },
      "spatialRelation": {
        "type": "string",
        "description": "Type of spatial relation for data aggregation ('buffer', 'nn', 'contains').",
        "enum": ["buffer", "nn", "contains"]
      },
      "spatialRelationValue": {
        "type": "number",
        "description": "Value associated with the spatial relation (e.g., buffer distance)."
      },
      "aggregationType": {
        "type": "string",
        "description": "Type of aggregation ('sum', 'mean', 'min', 'max').",
        "enum": ["sum", "mean", "min", "max"]
      },
      "streetColor": {
        "type": "string",
        "description": "Color for streets on the map.",
        "nullable": true
      },
      "streetWidth": {
        "type": "number",
        "description": "Width for streets on the map.",
        "nullable": true
      },
      "methodRow": {
        "type": "number",
        "description": "Row parameter for methods like 'matrix'.",
        "nullable": true
      },
      "methodColumn": {
        "type": "number",
        "description": "Column parameter for methods like 'matrix'.",
        "nullable": true
      },
      "queryAddress": {
        "type": "string",
        "description": "Address for a spatial query.",
        "nullable": true
      },
      "queryRadius": {
        "type": "number",
        "description": "Radius for a spatial query.",
        "nullable": true
      }
    },
    "required": [
      "unit",
      "unitDivide",
      "zoom",
      "method",
      "lineOpacity",
      "lineColor",
      "lineStrokeWidth",
      "lineHeight",
      "orientation",
      "alignment",
      "spatialRelation",
      "spatialRelationValue",
      "aggregationType"
    ],
    "additionalProperties": false
  }
}