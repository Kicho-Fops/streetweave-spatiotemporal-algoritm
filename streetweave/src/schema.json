{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ParsedSpec Array",
  "description": "An array of specifications for different layers.",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "name": {
        "type": "string",
        "description": "Optional name for the specification layer."
      },
      "unit": {
        "type": "string",
        "description": "The unit of analysis (e.g., 'segment', 'node', 'point').",
        "enum": ["segment", "node", "point"],
        "default": "segment"
      },
      "splits": {
        "type": "number",
        "description": "A split factor for the unit.",
        "default": 1
      },
      "data": {
        "type": "object",
        "description": "Paths to physical and thematic data layers.",
        "properties": {
          "physical": {
            "type": "string",
            "description": "Path to the physical layer data (e.g., GeoJSON file)."
          },
          "thematic": {
            "type": "string",
            "description": "Path to the thematic layer data (e.g., CSV file for points)."
          }
        },
        "required": ["physical", "thematic"],
        "additionalProperties": false
      },
      "relation": {
        "type": "object",
        "description": "Spatial relation and aggregation parameters.",
        "properties": {
          "spatial": {
            "type": "string",
            "description": "Type of spatial relation for data aggregation ('buffer', 'nn', 'contains').",
            "enum": ["buffer", "nn", "contains"],
            "default": "buffer"
          },
          "value": {
            "type": "number",
            "description": "Value associated with the spatial relation (e.g., buffer distance).",
            "default": 5
          },
          "type": {
            "type": "string",
            "description": "Type of aggregation ('sum', 'mean', 'min', 'max').",
            "enum": ["sum", "mean", "min", "max"],
            "default": "mean"
          }
        },
        "additionalProperties": false
      },
      "zoom": {
        "type": "array",
        "description": "The zoom level range for the map, specified as a [minimum_zoom, maximum_zoom] array.",
        "minItems": 2,
        "maxItems": 2,
        "items": {
          "type": "number",
          "description": "A single zoom level, typically an integer.",
          "minimum": 0,
          "maximum": 22
        },
        "default": [18, 18],
        "examples": [
          [0, 22],
          [5, 15],
          [18, 18]
        ]
      },
      "method": {
        "type": "string",
        "description": "The rendering method (e.g., 'line', 'rect', 'matrix', 'point', 'heatmap').",
        "enum": ["line", "rect", "matrix"],
        "default": "line"
      },
      "lineOpacity": {
        "oneOf": [
          { "type": "string" },
          { "type": "number", "minimum": 0, "maximum": 1 }
        ],
        "description": "Opacity for lines, can be a number (0-1) or a string (e.g., a field name).",
        "default": 1
      },
      "lineColor": {
        "type": "string",
        "description": "Color for lines (e.g., 'red', '#HEXCODE').",
        "default": "red"
      },
      "lineType": {
        "type": "string",
        "description": "Type of line (e.g., 'solid', 'dashed', 'dotted').",
        "default": "solid"
      },
      "lineStrokeWidth": {
        "oneOf": [
          { "type": "string" },
          { "type": "number", "minimum": 0 }
        ],
        "description": "Stroke width for lines. Can be a number or a string (field name).",
        "default": 1
      },
      "lineHeight": {
        "oneOf": [
          { "type": "string" },
          { "type": "number", "minimum": 0 }
        ],
        "description": "Height for lines. Can be a number or a string (field name).",
        "default": 1
      },
      "map": {
        "type": "object",
        "description": "Map styling properties.",
        "properties": {
          "streetColor": {
            "type": "string",
            "description": "Color for streets on the map.",
            "nullable": true
          },
          "streetWidth": {
            "type": "number",
            "description": "Width for streets on the map.",
            "minimum": 0,
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "orientation": {
        "type": "string",
        "description": "Orientation for rendering (e.g., 'parallel', 'perpendicular').",
        "enum": ["parallel", "perpendicular"],
        "nullable": true
      },
      "alignment": {
        "type": "string",
        "description": "Alignment for rendering (e.g., 'left', 'center', 'right').",
        "enum": ["left", "center", "right"],
        "nullable": true
      },
      "query": {
        "type": "object",
        "description": "Parameters for a spatial query.",
        "properties": {
          "address": {
            "type": "string",
            "description": "Address for a spatial query.",
            "nullable": true
          },
          "radius": {
            "type": "number",
            "description": "Radius for a spatial query.",
            "minimum": 0,
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "chart": {
        "type": "object",
        "description": "Optional Vega-Lite chart specification. Can be any valid JSON object.",
        "additionalProperties": true,
        "nullable": true
      },
      "methodRow": {
        "type": "number",
        "description": "Row parameter for methods like 'matrix'.",
        "nullable": true
      },
      "methodColumn": {
        "type": "number",
        "description": "Column parameter for methods like 'matrix'.",
        "nullable": true
      }
    },
    "required": [
      "data",
      "splits"
    ],
    "additionalProperties": false
  }
}